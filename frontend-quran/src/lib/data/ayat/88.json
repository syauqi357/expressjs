		"namaIndo": "Hari Pembalasan",
		"tempatTurun": "Makkiyah"
	},
	{
		"id": 5975,
		"suraId": 88,
		"verseID": 9,
		"ayahText": "لِّسَعْيِهَا رَاضِيَةٌ ۙ",
		"indoText": "merasa senang karena usahanya (sendiri),",
		"readText": "lisa'yihā rāḍiyah",
		"namaLatin": "Al-Gasyiyah",
		"namaArab": "الغاشية",
		"namaIndo": "Hari Pembalasan",
		"tempatTurun": "Makkiyah"
	},
	{
		"id": 5976,
		"suraId": 88,
