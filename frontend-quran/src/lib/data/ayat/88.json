		"namaIndo": "Hari Pembalasan",
		"tempatTurun": "Makkiyah"
	},
	{
		"id": 5983,
		"suraId": 88,
		"verseID": 17,
		"ayahText": "اَفَلَا يَنْظُرُوْنَ اِلَى الْاِبِلِ كَيْفَ خُلِقَتْۗ",
