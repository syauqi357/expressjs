    "namaLatin": "Al-Mutaffifin",
    "namaArab": "المطففين",
    "namaIndo": "Orang yang Curang",
    "tempatTurun": "Makkiyah"
  },
  {
    "id": 5862,
    "suraId": 83,
    "verseID": 15,
