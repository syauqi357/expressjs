    "namaArab": "الانشقاق",
    "namaIndo": "Terbelah",
    "tempatTurun": "Makkiyah"
  },
  {
    "id": 5886,
    "suraId": 84,
    "verseID": 3,
    "ayahText": "وَاِذَا الْاَرْضُ مُدَّتْۙ",
    "indoText": "dan apabila bumi diratakan,",
    "readText": "wa iżal-arḍu muddat",
    "namaLatin": "Al-Insyiqaq",
    "namaArab": "الانشقاق",
    "namaIndo": "Terbelah",
    "tempatTurun": "Makkiyah"
  },
  {
