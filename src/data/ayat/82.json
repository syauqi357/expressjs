    "namaLatin": "Al-Infitar",
    "namaArab": "الانفطار",
    "namaIndo": "Terbelah",
    "tempatTurun": "Makkiyah"
  },
  {
    "id": 5843,
    "suraId": 82,
    "verseID": 15,
    "ayahText": "يَصْلَوْنَهَا يَوْمَ الدِّيْنِ",
    "indoText": "Mereka masuk ke dalamnya pada hari pembalasan.",
    "readText": "yaṣlaunahā yaumad-dīn",
    "namaLatin": "Al-Infitar",
    "namaArab": "الانفطار",
    "namaIndo": "Terbelah",
    "tempatTurun": "Makkiyah"
  },
  {
    "id": 5844,
    "suraId": 82,
